# ---------- Infrastructure ----------
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=payments
POSTGRES_PORT=5432

NATS_PORT=4222
NATS_MONITOR_PORT=8222

# ---------- Shared App ----------
APP_NAME=highload-payments
APP_ENV=dev
LOG_LEVEL=INFO

POSTGRES_HOST=postgres
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

NATS_SERVERS=nats://nats:4222
NATS_STREAM_NAME=payments
NATS_OUTBOX_SUBJECT=payments.outbox
NATS_CONSUMER_DURABLE=dispatcher-webhooks

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8080

# ---------- Worker ----------
WORKER_BATCH_SIZE=100
WORKER_POLL_INTERVAL_SECONDS=0.5
WORKER_MAX_ATTEMPTS=10
WORKER_RETRY_BASE_SECONDS=1
WORKER_RETRY_MAX_SECONDS=60
WORKER_RETRY_JITTER_SECONDS=0.25

# ---------- Dispatcher ----------
WEBHOOK_TIMEOUT_SECONDS=3.0
DISPATCHER_POLL_INTERVAL_SECONDS=1.0
DISPATCHER_MAX_RETRIES=8
DISPATCHER_RETRY_BASE_SECONDS=1
DISPATCHER_RETRY_MAX_SECONDS=60
DISPATCHER_RETRY_JITTER_SECONDS=0.25
DISPATCHER_CONSUMER_ACK_WAIT_SECONDS=30
